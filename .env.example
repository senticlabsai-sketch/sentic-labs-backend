# ─── STRIPE ─────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_YOUR_KEY_HERE

# Get this by running: stripe listen --forward-to localhost:3001/webhook
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Create a recurring price in Stripe dashboard → Products → Add product
# Set price to $7.99/month, copy the price ID (starts with price_)
STRIPE_MONTHLY_PRICE_ID=price_YOUR_MONTHLY_PRICE_ID_HERE

# ─── REPLICATE ───────────────────────────────────────────────────────────────
# Get from https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_YOUR_TOKEN_HERE

# ─── APP ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://senticlabsai.com
PORT=3001
